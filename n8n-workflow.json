{
  "name": "Sentinel-AI — Fuzz & Heal Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sentinel-scan",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "c1a1b2d3-0001-4a00-8000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-80, 300],
      "webhookId": "sentinel-scan"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a0000001-0000-4000-8000-000000000001",
              "name": "target",
              "value": "={{ $json.body?.target || 'http://host.docker.internal:8080/api/user' }}",
              "type": "string"
            },
            {
              "id": "a0000001-0000-4000-8000-000000000002",
              "name": "category",
              "value": "={{ $json.body?.category || 'sql_injection' }}",
              "type": "string"
            },
            {
              "id": "a0000001-0000-4000-8000-000000000003",
              "name": "concurrency",
              "value": "={{ $json.body?.concurrency || 5 }}",
              "type": "number"
            }
          ]
        },
        "options": {}
      },
      "id": "c1a1b2d3-0002-4a00-8000-000000000002",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [160, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://healer:8001/fuzz",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "timeout": 180000
        }
      },
      "id": "c1a1b2d3-0003-4a00-8000-000000000003",
      "name": "Run MCP Fuzzer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nif (!data.ok) {\n  throw new Error('Fuzzer failed: ' + JSON.stringify(data.error || data));\n}\nconst input = $('Normalize Input').first().json;\nconst vulns = data.vulnerabilities || [];\nreturn [{\n  json: {\n    target: data.target || input.target,\n    category: input.category,\n    vulnerabilities: vulns,\n    vuln_count: vulns.length,\n    total_attempts: data.total_attempts || 0,\n    raw: data.raw,\n    scanned_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "c1a1b2d3-0004-4a00-8000-000000000004",
      "name": "Parse MCP Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-vuln-found",
              "leftValue": "={{ $json.vuln_count }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c1a1b2d3-0005-4a00-8000-000000000005",
      "name": "Vulnerability Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://healer:8001/heal",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "timeout": 300000
        }
      },
      "id": "c1a1b2d3-0007-4a00-8000-000000000007",
      "name": "Run Healing Agent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 180]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { status: 'healed', target: $('Parse MCP Response').item.json.target, category: $('Parse MCP Response').item.json.category, vulnerabilities: $('Parse MCP Response').item.json.vulnerabilities, vuln_count: $('Parse MCP Response').item.json.vuln_count, total_attempts: $('Parse MCP Response').item.json.total_attempts, scanned_at: $('Parse MCP Response').item.json.scanned_at, healer_ok: $json.ok, patch_log: $json.stdout, patch_stderr: $json.stderr } }}",
        "options": {}
      },
      "id": "c1a1b2d3-0008-4a00-8000-000000000008",
      "name": "Respond (Healed)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1360, 180]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { status: 'clean', target: $json.target, category: $json.category, total_attempts: $json.total_attempts, vulnerabilities: [], scanned_at: $json.scanned_at } }}",
        "options": {}
      },
      "id": "c1a1b2d3-0009-4a00-8000-000000000009",
      "name": "Respond (Clean)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1120, 420]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Normalize Input",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Normalize Input": {
      "main": [
        [
          {
            "node": "Run MCP Fuzzer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run MCP Fuzzer": {
      "main": [
        [
          {
            "node": "Parse MCP Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse MCP Response": {
      "main": [
        [
          {
            "node": "Vulnerability Found?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Vulnerability Found?": {
      "main": [
        [
          {
            "node": "Run Healing Agent",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Respond (Clean)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run Healing Agent": {
      "main": [
        [
          {
            "node": "Respond (Healed)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "pinData": {},
  "triggerCount": 0,
  "tags": []
}